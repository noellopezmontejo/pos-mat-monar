{
  "name": "posmatmonar",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "server": "node src/api/server.js",
    "electron": "wait-on http://0.0.0.0:5174 && electron .",
    "start": "concurrently \"npm run server\" \"npm run dev\" \"npm run electron\"",
    "create-admin": "node scripts/create-admin.js",
    "clean-db": "node scripts/clean-db.js",
    "clean-clients": "node scripts/clean-1-clients.js",
    "clean-lines": "node scripts/clean-tables.js ProductLine",
    "clean-brands": "node scripts/clean-tables.js ProductBrand",
    "clean-categories": "node scripts/clean-tables.js Category",
    "clean-inventory": "node scripts/clean-tables.js Product",
    "clean-unused": "node scripts/clean-unused-categories.js",
    "clean-purchases": "node scripts/clean-3-purchases.js",
    "clean-sales": "node scripts/clean-4-sales.js",
    "clean-kardex": "node scripts/clean-5-kardex.js",
    "build": "vite build",
    "preview": "vite preview",
    "package": "vite build && electron-builder --windows"
  },
  "build": {
    "appId": "com.posmatmonar.app",
    "productName": "PosMatMonar",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PosMatMonar"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@prisma/client": "^5.22.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@tailwindcss/postcss": "^4.2.2",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dexie": "^4.4.1",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fast-csv": "^5.0.5",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "morgan": "^1.10.1",
    "mssql": "^12.2.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "tedious": "^19.2.1",
    "uuid": "^13.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "xlsx": "^0.18.5"
  }
}
